# Data Contracts Configuration

# Inference Settings
DEFAULT_SAMPLE_SIZE=1000
DEFAULT_CONFIDENCE_THRESHOLD=0.95

# Drift Detection Settings
DEFAULT_DRIFT_THRESHOLD=0.1
ENABLE_STATISTICAL_TESTS=true

# Validation Settings
ALLOW_EXTRA_FIELDS=false
STRICT_TYPE_CHECKING=true

# Logging
LOG_LEVEL=INFO
LOG_FILE=/app/logs/contracts.log

# Performance
BATCH_SIZE=10000
MAX_WORKERS=4

# Output
OUTPUT_FORMAT=json
VERBOSE=false

